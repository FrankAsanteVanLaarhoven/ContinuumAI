{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://continuum.dev/protocol/cip-002-intent.schema.json",
  "title": "CIP-002 Intent Envelope",
  "description": "A machine-verifiable statement of purpose, scope, prohibitions, constraints, and required evidence. NOT free-form prompt text.",
  "type": "object",
  "additionalProperties": false,
  "required": ["owner_id", "actor_id", "tenant_id", "purpose", "constraints"],
  "properties": {
    "cip": { "const": "CIP-002" },
    "intent_id": { "type": "string" },
    "owner_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "requested_operations": { "type": "array", "items": { "type": "string" } },
    "prohibited_operations": { "type": "array", "items": { "type": "string" } },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximum_data_classification",
        "geographic_boundary",
        "valid_until",
        "maximum_cost_gbp"
      ],
      "properties": {
        "maximum_data_classification": {
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "geographic_boundary": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "valid_until": { "type": "string", "format": "date-time" },
        "maximum_cost_gbp": { "type": "number", "minimum": 0 }
      }
    },
    "required_evidence": { "type": "array", "items": { "type": "string" } },
    "human_gate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_for": { "type": "array", "items": { "type": "string" } }
      }
    },
    "actor_geo": { "type": "string" },
    "model_id": { "type": ["string", "null"] },
    "agent_build": { "type": ["string", "null"] },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
