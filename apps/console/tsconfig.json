{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "react", "react-dom"],
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "paths": { "@/*": ["./*"] }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
